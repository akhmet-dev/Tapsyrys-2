# ================================================================
# .env.example — Орта айнымалыларының қауіпсіз үлгісі
#
# НҰСҚАУЛЫҚ:
#   1. Бұл файлды .env деп көшіріңіз:
#      cp .env.example .env
#   2. Төмендегі мәндерді өзіңіздің нақты деректеріңізбен алмастырыңыз
#   3. .env файлын ешқашан git-ке қоспаңыз! (.gitignore тексеріңіз)
# ================================================================

# ────────────────────────────────────────
# СЕРВЕР КОНФИГУРАЦИЯСЫ
# ────────────────────────────────────────

# Сервер тыңдайтын порт нөмірі
# Render.com автоматты орнатады, өзгертпеңіз
PORT=5000

# Орта атауы: development | production | test
NODE_ENV=development

# ────────────────────────────────────────
# MONGODB ДЕРЕКҚОР БАЙЛАНЫСЫ
# ────────────────────────────────────────

# Жергілікті MongoDB (тек даму үшін)
# Мысал: mongodb://localhost:27017/university_admissions
#
# MongoDB Atlas (өндіріс үшін ұсынылады)
# Мысал: mongodb+srv://<username>:<password>@cluster0.mongodb.net/<dbname>?retryWrites=true&w=majority
#
# Atlas-та аккаунт жасау: https://www.mongodb.com/atlas
MONGO_URI=mongodb://localhost:27017/university_admissions

# ────────────────────────────────────────
# JWT АУТЕНТИФИКАЦИЯ
# ────────────────────────────────────────

# JWT токенін қол қою үшін пайдаланылатын құпия кілт
# ӨНДІРІСТЕ: кем дегенде 64 таңбалы кездейсоқ жол пайдаланыңыз
# Генерациялау: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_STRING_IN_PRODUCTION

# JWT токенінің жарамдылық мерзімі
# Форматтар: 7d (7 күн), 24h (24 сағат), 60m (60 минут), 3600s (секунд)
JWT_EXPIRES_IN=7d

# ────────────────────────────────────────
# CORS КОНФИГУРАЦИЯСЫ
# ────────────────────────────────────────

# Frontend қосымшасының URL мекенжайы
# Жергілікті даму: http://localhost:5173
# Vercel deploy: https://your-app-name.vercel.app
CLIENT_URL=http://localhost:5173

# ────────────────────────────────────────
# EMAIL ХАБАРЛАМА (GMAIL SMTP)
# ────────────────────────────────────────

# Gmail электрондық пошта мекенжайыңыз
# Мысал: your.email@gmail.com
EMAIL_USER=your.email@gmail.com

# Gmail App Password (2FA қосулы болса қолданылады)
# Алу жолы: Google Account → Security → 2-Step Verification → App Passwords
# ЕСКЕРТУ: Gmail-дің кәдімгі құпия сөзі жұмыс істемейді — App Password қолданыңыз
# Егер EMAIL_USER немесе EMAIL_PASS бос болса — email жіберілмейді (қате шықпайды)
EMAIL_PASS=your_gmail_app_password
