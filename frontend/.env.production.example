# Өндіріс орта айнымалылары үлгісі
# Vercel Dashboard → Settings → Environment Variables ішіне қосыңыз
# Бұл файлды .gitignore-ға қоспаңыз (нақты мән жоқ, қауіпсіз)

# Render.com-дағы backend URL мекенжайы
# Мысал: https://university-admissions-api.onrender.com
VITE_API_URL=https://your-backend-name.onrender.com
